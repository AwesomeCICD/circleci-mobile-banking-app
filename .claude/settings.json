{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_comment": "Generated by chunk init.",
  "permissions": {
    "allow": [
      "Bash(chunk:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash(git commit*)",
        "hooks": [
          {
            "type": "command",
            "command": "cd ${CLAUDE_PROJECT_DIR:-.}/miniapps/payments && npm ci && npm run bundle:ios",
            "timeout": 360
          },
          {
            "type": "command",
            "command": "cd ${CLAUDE_PROJECT_DIR:-.}/miniapps/transfers && npm ci && npm run bundle:ios",
            "timeout": 360
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "chunk validate",
            "timeout": 600
          }
        ]
      }
    ]
  }
}
